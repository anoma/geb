/-! ### Precomposition on codes

Precomposition of an `IR` code along a coproduct (the `Î³^i` of
[HancockMcBrideGhaniMalatestaAltenkirch2013], Lemma 4, which
asserts existence only; the construction here is the project's):
`precomp Q i` transports a code from `I` to a code over the
same `I`, replacing every recursive-argument decoding by its
image under `i` when resolved, or leaving it as a fresh
recursive argument otherwise. `iota` and `sigma` subcodes push
through unchanged (up to `ULift`); a `delta B c` subcode becomes
a `sigma` over classifiers `B â†’ Q âŠ• PUnit` followed by a `delta`
over the classifier's unresolved elements, recursing into `c` at
the assignment merging `i`-images with the fresh decodings.
-/

universe uQ

/-- The assignment merging, along a classifier `c` of `B` into
`Q âŠ• PUnit`, the `i`-images of the resolved (`Q`-classified)
elements with the decodings `j` of the unresolved elements. -/
def precompMerge (Q : Type uQ) (i : Q â†’ I) {B : Type uB}
    (c : ArrowSumClassifier.{uB, uQ, uQ} B Q)
    (j : ArrowSumUnresolved c â†’ I) : B â†’ I :=
  Sum.elim i _root_.id âˆ˜ arrowSumMerge c j

/-- The algebra computing one step of `IR.precomp`: `iota` and
`sigma` push through (up to `ULift`); `delta` becomes a `sigma`
over classifiers followed by a `delta` over the unresolved
arity elements. -/
def precompAlg (Q : Type uQ) (i : Q â†’ I) :
    Alg.{uA, uB, uI, uO, max (max uA uB uQ + 1) (uB + 1) uI uO}
      I O (IR.{max uA uB uQ, uB, uI, uO} I O) :=
  âŸ¨fun o â†¦ iota I O o,
    fun A f â†¦ sigma I O (ULift.{max uB uQ} A) (f âˆ˜ ULift.down),
    fun B f â†¦
      sigma I O (ULift.{uA} (B â†’ Q âŠ• PUnit.{uQ + 1})) (fun cl â†¦
        delta I O {b : B // cl.down b = Sum.inr PUnit.unit} (fun j â†¦
          f (precompMerge I Q i cl.down j)))âŸ©

/-- Precomposition on codes (the `Î³^i` of
[HancockMcBrideGhaniMalatestaAltenkirch2013], Lemma 4, which
asserts existence only; this construction is the project's):
`âŸ¦precomp Q i Î³âŸ§ k` is isomorphic to `âŸ¦Î³âŸ§` at the coproduct of
`âŸ¨Q, iâŸ©` with `k`. -/
def precomp (Q : Type uQ) (i : Q â†’ I) :
    IR.{uA, uB, uI, uO} I O â†’ IR.{max uA uB uQ, uB, uI, uO} I O :=
  elimAlg I O (IR.{max uA uB uQ, uB, uI, uO} I O) (precompAlg I O Q i)

/-- Computation rule for `IR.precomp` at `IR.iota`: unchanged
(part of Lemma 4 of [HancockMcBrideGhaniMalatestaAltenkirch2013]). -/
theorem precomp_iota (Q : Type uQ) (i : Q â†’ I) (o : O) :
    precomp I O Q i (iota I O o) = iota I O o :=
  rfl

/-- Computation rule for `IR.precomp` at `IR.sigma`: the arity is
lifted (`ULift`), and `precomp` recurses into each subcode (part of
Lemma 4 of [HancockMcBrideGhaniMalatestaAltenkirch2013]). -/
theorem precomp_sigma (Q : Type uQ) (i : Q â†’ I) (A : Type uA)
    (c : A â†’ IR.{uA, uB, uI, uO} I O) :
    precomp I O Q i (sigma I O A c) =
      sigma I O (ULift.{max uB uQ} A)
        (fun a â†¦ precomp I O Q i (c a.down)) :=
  rfl

/-- Computation rule for `IR.precomp` at `IR.delta`: a `sigma` over
classifiers `B â†’ Q âŠ• PUnit`, then a `delta` over the unresolved
arity elements, recursing into the subcode at the merged
assignment (part of Lemma 4 of
[HancockMcBrideGhaniMalatestaAltenkirch2013]). -/
theorem precomp_delta (Q : Type uQ) (i : Q â†’ I) (B : Type uB)
    (c : (B â†’ I) â†’ IR.{uA, uB, uI, uO} I O) :
    precomp I O Q i (delta I O B c) =
      sigma I O (ULift.{uA} (ArrowSumClassifier.{uB, uQ, uQ} B Q))
        (fun cl â†¦ delta I O (ArrowSumUnresolved cl.down)
          (fun j â†¦ precomp I O Q i (c (precompMerge I Q i cl.down j)))) :=
  rfl

/-- The per-code statement of Lemma 4
([HancockMcBrideGhaniMalatestaAltenkirch2013]): interpreting a code
precomposed along `Q, i` is isomorphic to interpreting the code
directly at the coproduct object `FreeCoprodCompDisc.plus âŸ¨Q, iâŸ© k`. -/
def PrecompIsoMotive (Î³ : IR.{max uA uB, uB, uI, uO} I O) :
    Type (max (max uA uB + 1) uI) :=
  (Q : Type uB) â†’ (i : Q â†’ I) â†’
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) â†’
    FreeCoprodCompDisc.Iso O
      (interpObj I O (precomp I O Q i Î³) k)
      (interpObj I O Î³ (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k))

/-- `PrecompIsoMotive` at the constant (`iota`) code: `interpObj`
ignores its argument at an `iota` code, so both sides are the same
object and the identity isomorphism suffices. -/
def precompIsoIota (o : O) : PrecompIsoMotive I O (iota I O o) :=
  fun _ _ k â†¦ FreeCoprodCompDisc.Iso.refl O (interpObj I O (iota I O o) k)

/-- `PrecompIsoMotive` at the dependent sum (`sigma`) code: by
`precomp_sigma`, both sides are indexed coproducts of subcode
interpretations, related componentwise by the inductive hypotheses
`ih` via `coprodIso` over the equivalence stripping the `ULift` that
`precomp_sigma` introduces. -/
def precompIsoSigma (A : Type (max uA uB))
    (c : A â†’ IR.{max uA uB, uB, uI, uO} I O)
    (ih : (a : A) â†’ PrecompIsoMotive I O (c a)) :
    PrecompIsoMotive I O (sigma I O A c) :=
  fun Q i k â†¦
    FreeCoprodCompDisc.coprodIso O (ULift.{uB} A) A Equiv.ulift
      (fun a â†¦ interpObj I O (precomp I O Q i (c a.down)) k)
      (fun a â†¦ interpObj I O (c a) (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k))
      (fun a â†¦ ih a.down Q i k)

/-- The merged assignment `precompMerge`, taking the resolved elements
of `c` from the `i`-images and the unresolved elements from the
`k`-decodings of a direction assignment `j`, equals the cotuple
`Sum.elim i k.2` reindexed along the reassembled function
`arrowSumMerge c j`. This aligns the `delta` subcode argument used on
the precomposed side with the one used on the direct side. -/
theorem precompMerge_elim (Q : Type uB) (i : Q â†’ I)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) (B : Type uB)
    (c : ArrowSumClassifier.{uB, uB, uB} B Q)
    (j : ArrowSumUnresolved c â†’ k.1) :
    precompMerge I Q i c (k.2 âˆ˜ j) = Sum.elim i k.2 âˆ˜ arrowSumMerge c j :=
  funext (fun b â†¦
    Sum.casesOn (motive := fun t â†¦ c b = t â†’
        (precompMerge I Q i c (k.2 âˆ˜ j) b = (Sum.elim i k.2 âˆ˜ arrowSumMerge c j) b))
      (c b)
      (fun q h â†¦
        (congrArg (Sum.elim i _root_.id) (arrowSumMerge_eq c (k.2 âˆ˜ j) b (Sum.inl q) h)).trans
          (congrArg (Sum.elim i k.2) (arrowSumMerge_eq c j b (Sum.inl q) h)).symm)
      (fun u h â†¦
        (congrArg (Sum.elim i _root_.id) (arrowSumMerge_eq c (k.2 âˆ˜ j) b (Sum.inr u) h)).trans
          (congrArg (Sum.elim i k.2) (arrowSumMerge_eq c j b (Sum.inr u) h)).symm)
      rfl)

/-- The `delta`-case inner isomorphism at a fixed classifier `cl`: over
the unresolved-arity coproduct, each precomposed subcode interpretation
is related, by the inductive hypothesis `ih`, to the direct
interpretation at the merged assignment, whose subcode argument
`precompMerge_elim` then rewrites to `Sum.elim i k.2 âˆ˜ arrowSumMerge
cl g`. -/
def precompIsoDeltaInner (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (ih : (m : B â†’ I) â†’ PrecompIsoMotive I O (c m)) (Q : Type uB) (i : Q â†’ I)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) (cl : ArrowSumClassifier.{uB, uB, uB} B Q) :
    FreeCoprodCompDisc.Iso O
      (FreeCoprodCompDisc.coprod O (ArrowSumUnresolved cl â†’ k.1)
        (fun g â†¦ interpObj I O (precomp I O Q i (c (precompMerge I Q i cl (k.2 âˆ˜ g)))) k))
      (FreeCoprodCompDisc.coprod O (ArrowSumUnresolved cl â†’ k.1)
        (fun g â†¦ interpObj I O (c (Sum.elim i k.2 âˆ˜ arrowSumMerge cl g))
          (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k))) :=
  FreeCoprodCompDisc.coprodIso O ({b // cl b = Sum.inr PUnit.unit} â†’ k.1)
    ({b // cl b = Sum.inr PUnit.unit} â†’ k.1) (Equiv.refl _)
    (fun g â†¦ interpObj I O (precomp I O Q i (c (precompMerge I Q i cl (k.2 âˆ˜ g)))) k)
    (fun g â†¦ interpObj I O (c (Sum.elim i k.2 âˆ˜ arrowSumMerge cl g))
      (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k))
    (fun g â†¦ FreeCoprodCompDisc.Iso.trans O (ih (precompMerge I Q i cl (k.2 âˆ˜ g)) Q i k)
      (FreeCoprodCompDisc.isoOfEq O
        (congrArg (fun m â†¦ interpObj I O (c m) (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k))
          (precompMerge_elim I Q i k B cl g))))

/-- The `delta` interpretation reshuffled as a coproduct, over the
direction classifiers `cl : B â†’ Q âŠ• PUnit`, of coproducts, over the
`k`-assignments of each classifier's unresolved elements, of the
interpretations of the direct subcodes at the coproduct object
`FreeCoprodCompDisc.plus âŸ¨Q, iâŸ© k`. This is the common endpoint of
`precompIsoDeltaStrip` and `precompIsoDeltaReshuffle`. -/
abbrev precompDeltaCoprod (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O) (Q : Type uB) (i : Q â†’ I)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :
    FreeCoprodCompDisc.{max uA uB, uO} O :=
  FreeCoprodCompDisc.coprod O (ArrowSumClassifier.{uB, uB, uB} B Q)
    (fun cl â†¦ FreeCoprodCompDisc.coprod O (ArrowSumUnresolved cl â†’ k.1)
      (fun g â†¦ interpObj I O (c (Sum.elim i k.2 âˆ˜ arrowSumMerge cl g))
        (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k)))

/-- The `delta`-case classifier-stripping isomorphism: strips the
`ULift` on the `sigma`-over-classifiers index introduced by
`precomp_delta` (via `Equiv.ulift`) and, componentwise, applies
`precompIsoDeltaInner`. The source is definitionally the precomposed
`delta` interpretation. -/
def precompIsoDeltaStrip (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (ih : (m : B â†’ I) â†’ PrecompIsoMotive I O (c m)) (Q : Type uB) (i : Q â†’ I)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :
    FreeCoprodCompDisc.Iso O
      (interpObj I O (precomp I O Q i (delta I O B c)) k)
      (precompDeltaCoprod I O B c Q i k) :=
  FreeCoprodCompDisc.coprodIso O (ULift.{max uA uB} (B â†’ Q âŠ• PUnit.{uB + 1}))
    (B â†’ Q âŠ• PUnit.{uB + 1}) Equiv.ulift
    (fun cl â†¦ interpObj I O (delta I O {b // cl.down b = Sum.inr PUnit.unit}
      (fun j â†¦ precomp I O Q i (c (precompMerge I Q i cl.down j)))) k)
    (fun cl â†¦ FreeCoprodCompDisc.coprod O ({b // cl b = Sum.inr PUnit.unit} â†’ k.1)
      (fun g â†¦ interpObj I O (c (Sum.elim i k.2 âˆ˜ arrowSumMerge cl g))
        (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k)))
    (fun cl â†¦ precompIsoDeltaInner I O B c ih Q i k cl.down)

/-- The `delta`-case reshuffling isomorphism: the double coproduct over
classifiers and their unresolved assignments is regrouped, via the
sigma-associativity equivalence and `arrowSumEquivSigma`, into the
single coproduct over assignments `B â†’ Q âŠ• k.1` that is definitionally
the direct `delta` interpretation at the coproduct object. -/
def precompIsoDeltaReshuffle (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O) (Q : Type uB) (i : Q â†’ I)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :
    FreeCoprodCompDisc.Iso O
      (precompDeltaCoprod I O B c Q i k)
      (interpObj I O (delta I O B c) (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k)) :=
  âŸ¨(Equiv.sigmaAssoc (fun (cl : B â†’ Q âŠ• PUnit.{uB + 1})
        (g : {b // cl b = Sum.inr PUnit.unit} â†’ k.1) â†¦
      (interpObj I O (c (Sum.elim i k.2 âˆ˜ arrowSumMerge cl g))
        (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k)).1)).symm.trans
    (Equiv.sigmaCongrLeft
      (Î² := fun (g' : B â†’ Q âŠ• k.1) â†¦
        (interpObj I O (c (Sum.elim i k.2 âˆ˜ g')) (FreeCoprodCompDisc.plus I âŸ¨Q, iâŸ© k)).1)
      (arrowSumEquivSigma B Q k.1).symm),
    funext (fun _ â†¦ rfl)âŸ©

/-- `PrecompIsoMotive` at the dependent product (`delta`) code (the
`delta` case of Lemma 4 of [HancockMcBrideGhaniMalatestaAltenkirch2013]):
by `precomp_delta` the precomposed side is a `sigma` over classifiers of
a `delta` over their unresolved elements; `precompIsoDeltaStrip` relates
it (using `ih`) to the double coproduct at the merged assignments, and
`precompIsoDeltaReshuffle` regroups that into the direct `delta`
interpretation at the coproduct object. -/
def precompIsoDelta (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (ih : (m : B â†’ I) â†’ PrecompIsoMotive I O (c m)) :
    PrecompIsoMotive I O (delta I O B c) :=
  fun Q i k â†¦
    FreeCoprodCompDisc.Iso.trans O (precompIsoDeltaStrip I O B c ih Q i k)
      (precompIsoDeltaReshuffle I O B c Q i k)

/-- The step argument to the recursor which generates the family of
isomorphisms of Lemma 4, dispatching on the shape to the constant,
dependent sum, and dependent product cases, as `interpMorStep` does for
the morphism map. -/
def interpPrecompIsoStep :
    RecStep.{max uA uB, uB, uI, uO, max (max uA uB + 1) uI} I O
      (PrecompIsoMotive I O) :=
  fun s c m â†¦ match s with
  | Sum.inl o => precompIsoIota I O o
  | Sum.inr (Sum.inl A) =>
      precompIsoSigma I O A (fun a â†¦ c (ULift.up a)) (fun a â†¦ m (ULift.up a))
  | Sum.inr (Sum.inr B) =>
      precompIsoDelta I O B (fun f â†¦ c (ULift.up f)) (fun f â†¦ m (ULift.up f))

/-- Lemma 4 of [HancockMcBrideGhaniMalatestaAltenkirch2013]: interpreting
a code precomposed along `Q, i` is isomorphic to interpreting the code
directly at the coproduct object `FreeCoprodCompDisc.plus âŸ¨Q, iâŸ© k`. The
paper asserts an equality; the recorded deviation replaces it with the
isomorphism `PrecompIsoMotive`, obtained by `IR.rec` from the per-shape
steps. -/
def interpPrecompIso (Î³ : IR.{max uA uB, uB, uI, uO} I O) :
    PrecompIsoMotive I O Î³ :=
  rec I O (interpPrecompIsoStep I O) Î³

/-- The name type of the `delta` interpretation regrouped by the
fibers of the direction-decoding composite `k.2 âˆ˜ g`: over each
direction assignment `i : B â†’ I`, the fiber `{g : B â†’ k.1 // k.2 âˆ˜ g =
i}` paired with the name type of the subcode interpretation `c i` at
`k`. -/
abbrev InterpDeltaFiberSigma (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :=
  Î£ i : B â†’ I, Î£ _ : {g : B â†’ k.1 // k.2 âˆ˜ g = i}, (interpObj I O (c i) k).1

/-- The grouping equivalence underlying Lemma 3 of
[HancockMcBrideGhaniMalatestaAltenkirch2013]: the directions
`g : B â†’ k.1` of the `delta` interpretation are grouped by their
composite `k.2 âˆ˜ g : B â†’ I` with the decoding of `k`, presenting each
group as a fiber of that composite. -/
def interpDeltaIsoGroup (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :
    (interpObj I O (delta I O B c) k).1 â‰ƒ InterpDeltaFiberSigma I O B c k :=
  sigmaCompEquivSigmaFiber (f := (k.2 âˆ˜ Â·)) (N := fun i â†¦ (interpObj I O (c i) k).1)

/-- The direction-replacement equivalence underlying Lemma 3 of
[HancockMcBrideGhaniMalatestaAltenkirch2013]: per composite `i : B â†’ I`,
the fiber `{g : B â†’ k.1 // k.2 âˆ˜ g = i}` is the morphism type
`Hom I (lift âŸ¨B, iâŸ©) k` (by `homLiftEquiv`), so each grouped summand
becomes the name type of the copower. The projection-based form (rather
than `Equiv.sigmaCongrLeft'`) keeps the second component untransported,
so the decodings agree definitionally. -/
def interpDeltaIsoHom (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :
    InterpDeltaFiberSigma I O B c k â‰ƒ
      Î£ i : B â†’ I, Î£ _ : FreeCoprodCompDisc.Hom I
          (FreeCoprodCompDisc.lift.{uB, uI, max uA uB} I âŸ¨B, iâŸ©) k,
        (interpObj I O (c i) k).1 :=
  sigmaCongrRight' (fun i â†¦
    { toFun := fun q â†¦ âŸ¨(FreeCoprodCompDisc.homLiftEquiv I âŸ¨B, iâŸ© k).symm q.1, q.2âŸ©,
      invFun := fun q â†¦ âŸ¨FreeCoprodCompDisc.homLiftEquiv I âŸ¨B, iâŸ© k q.1, q.2âŸ©,
      left_inv := fun q â†¦
        congrArg (fun s â†¦ (âŸ¨s, q.2âŸ© : Î£ _ : {g : B â†’ k.1 // k.2 âˆ˜ g = i},
            (interpObj I O (c i) k).1))
          ((FreeCoprodCompDisc.homLiftEquiv I âŸ¨B, iâŸ© k).apply_symm_apply q.1),
      right_inv := fun q â†¦
        congrArg (fun s â†¦ (âŸ¨s, q.2âŸ© : Î£ _ : FreeCoprodCompDisc.Hom I
            (FreeCoprodCompDisc.lift.{uB, uI, max uA uB} I âŸ¨B, iâŸ©) k,
            (interpObj I O (c i) k).1))
          ((FreeCoprodCompDisc.homLiftEquiv I âŸ¨B, iâŸ© k).symm_apply_apply q.1) })

/-- Lemma 3 of [HancockMcBrideGhaniMalatestaAltenkirch2013]:
interpreting the dependent product (`delta`) code at `k` is isomorphic
to the indexed coproduct, over the direction assignments `i : B â†’ I`,
of the copower of the interpretation of the subcode `c i` by the
morphisms `Hom I (lift âŸ¨B, iâŸ©) k`. The paper states a natural
isomorphism; the recorded deviation states it pointwise at `k`, because
natural transformations between interpretations are not yet defined.
The isomorphism composes `interpDeltaIsoGroup` and `interpDeltaIsoHom`;
its decodings agree definitionally. -/
def interpDeltaIso (B : Type uB)
    (c : (B â†’ I) â†’ IR.{max uA uB, uB, uI, uO} I O)
    (k : FreeCoprodCompDisc.{max uA uB, uI} I) :
    FreeCoprodCompDisc.Iso O
      (interpObj I O (delta I O B c) k)
      (FreeCoprodCompDisc.coprod O (B â†’ I) (fun i â†¦
        FreeCoprodCompDisc.copower O
          (FreeCoprodCompDisc.Hom I
            (FreeCoprodCompDisc.lift.{uB, uI, max uA uB} I âŸ¨B, iâŸ©) k)
          (interpObj I O (c i) k))) :=
  âŸ¨(interpDeltaIsoGroup I O B c k).trans (interpDeltaIsoHom I O B c k),
    funext (fun _ â†¦ rfl)âŸ©

end IR

section Universes

/-! ### Universes closed under dependent sums and products

The code of the universe generated by an arbitrary family of starting
types and closed under dependent sums and dependent products,
combining Examples 2.5 and 2.6 of
[GhaniNordvallForsbergMalatesta2015]: the coproduct of one `iota`
code per starting type (in place of the examples' single `iota` code
for the natural numbers), one dependent-sum former, and one
dependent-product former. The universe is an endofunctor example
(`IR I I`), so the input and output index types coincide.
-/

universe uK uT

/-- The binder-former subcode shared by `univSigma` and `univPi`: one
recursive argument (the type bound by the binder), then recursive
arguments indexed by its decoding (the family of types under the
binder), decoding to `former` applied to the decodings. -/
def univBinder.{v} (former : (X : Type v) â†’ (X â†’ Type v) â†’ Type v) :
    IR.{v, v, v + 1, v + 1} (Type v) (Type v) :=
  IR.delta (Type v) (Type v) PUnit.{v + 1} (fun f â†¦
    IR.delta (Type v) (Type v) (f PUnit.unit) (fun q â†¦
      IR.iota (Type v) (Type v) (former (f PUnit.unit) q)))

/-- The dependent-sum-former subcode of a universe code. -/
def univSigma.{v} : IR.{v, v, v + 1, v + 1} (Type v) (Type v) :=
  univBinder (fun X q â†¦ Î£ x : X, q x)

/-- The dependent-product-former subcode of a universe code. -/
def univPi.{v} : IR.{v, v, v + 1, v + 1} (Type v) (Type v) :=
  univBinder (fun X q â†¦ (x : X) â†’ q x)

variable (K : Type uK) (T : K â†’ Type uT)

/-- The starting-type subcode of a universe code: an `iota` code
decoding to the lifted starting type selected by `k`. -/
def univIota (k : K) :
    IR.{max uK uT, max uK uT, max uK uT + 1, max uK uT + 1}
      (Type (max uK uT)) (Type (max uK uT)) :=
  IR.iota (Type (max uK uT)) (Type (max uK uT)) (ULift.{uK} (T k))

/-- The constructors of the universe generated by a family of starting
types: one nullary constructor per starting type, a dependent-sum
former, and a dependent-product former. -/
def UnivConstructor : Type (max uK uT) :=
  K âŠ• PUnit.{max uK uT + 1} âŠ• PUnit.{max uK uT + 1}

/-- The subcode of the universe code selected by each constructor. -/
def univConstructorCode :
    UnivConstructor.{uK, uT} K â†’
      IR.{max uK uT, max uK uT, max uK uT + 1, max uK uT + 1}
        (Type (max uK uT)) (Type (max uK uT)) :=
  Sum.elim (univIota K T)
    (Sum.elim (fun _ â†¦ univSigma.{max uK uT}) (fun _ â†¦ univPi.{max uK uT}))

/-- The code of the universe generated by the starting types `T`: the
coproduct, over `UnivConstructor`, of the subcodes. The universe
itself â€” containing the (lifted) starting types and closed under
dependent sums and dependent products â€” is the initial algebra of the
code's interpretation; this file provides the code and the
interpretation, not the initial algebra. -/
def univCode :
    IR.{max uK uT, max uK uT, max uK uT + 1, max uK uT + 1}
      (Type (max uK uT)) (Type (max uK uT)) :=
  IR.sigma (Type (max uK uT)) (Type (max uK uT)) (UnivConstructor.{uK, uT} K)
    (univConstructorCode K T)

/-- The object map of the interpretation of `univCode`. -/
def univEndo :
    FreeCoprodCompDisc.Endo.{max uK uT, max uK uT + 1} (Type (max uK uT)) :=
  IR.interpObj (Type (max uK uT)) (Type (max uK uT)) (univCode K T)

/-- The morphism map of the interpretation of `univCode` (the object
map is `univEndo`). -/
def univEndoMor :
    FreeCoprodCompDisc.EndoMor (Type (max uK uT)) (univEndo K T) :=
  IR.interpMor (Type (max uK uT)) (Type (max uK uT)) (univCode K T)

end Universes

section Container

/-! ### Simple containers as `IR` codes over the unit type

A simple container â€” a shape type `S` and a direction family
`P : S â†’ Type` â€” is mathlib's `PFunctor`. Example 1 of
[HancockMcBrideGhaniMalatestaAltenkirch2013] represents such a
container by an `IR` code over the unit type (the paper's `IR 1 1`):
a `sigma` over the shapes, then for each shape a `delta` over its
directions, terminating in the constant `iota` code at the unit. The
initial algebra of the code's interpretation amounts to Martin-LÃ¶f's
well-ordering type (the paper's `W S P`; mathlib's `WType`); the
initial algebra itself is not constructed here.
-/

/-- The `IR` code over the unit type representing the container `F`:
a `sigma` over the shapes `F.A`, then for each shape a `delta` over
its directions `F.B`, terminating in `iota` at the unit element.
Follows Example 1 of
[HancockMcBrideGhaniMalatestaAltenkirch2013]. -/
def contCode (F : PFunctor.{uA, uB}) : IR.{uA, uB, uI, uO} PUnit PUnit :=
  IR.sigma PUnit PUnit F.A
    (fun s â†¦ IR.delta PUnit PUnit (F.B s)
      (fun _ â†¦ IR.iota PUnit PUnit PUnit.unit))

end Container

