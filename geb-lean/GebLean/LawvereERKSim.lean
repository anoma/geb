      rw [h_inner_idx] at h_eq
      have h_idx_eq :
          (⟨2 + a +
              gsPrefixSum (fun i => compileERFrag (gs i)) m.val
              + ((compileERFrag (gs m)).outputReg).val, by
            have hO : ((compileERFrag (gs m)).outputReg).val
                < (compileERFrag (gs m)).numRegs :=
