      have h_out : tmpFin.val < gsBase_m ∨ gsBase_m + (frag_gs m).numRegs ≤ tmpFin.val := by
        right
        have h_le : gsBase_m + (frag_gs m).numRegs ≤ fBase := h_gsBlock_m
